let Resource = struct(counter: MutPtr(i32))

extend Resource: Drop {
  let drop(mut borrow self)(): () = unsafe do {
    *self.counter = *self.counter + 1
  }
}

let main(): i32 = {
  let mut count = 0
  do {
    let counter = MutPtr(mut borrow count)
    let first = box_new(Resource(counter))
    let second = first
  }
  41 + count
}
